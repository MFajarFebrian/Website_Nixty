{"file":"products-K8dd97T7.js","mappings":";;;;;;;;;;;;;;;;;;;;;AAWM,UAAA,WAAW,IAAe,EAAE;AAC5B,UAAA,UAAU,IAAI,IAAI;AAClB,UAAA,QAAQ,IAAI,IAAI;AAChB,UAAA,cAAc,IAAI,EAAE;AACpB,UAAA,mBAAmB,IAAI,EAAE;AACzB,UAAA,aAAa,IAAc,EAAE;AAGnC,mBAAe,gBAAgB;AAC7B,cAAQ,QAAQ;AAChB,YAAM,QAAQ;AAEV,UAAA;AAEF,YAAI,MAAM;AACJ,cAAA,SAAS,IAAI,gBAAgB;AAEnC,YAAI,YAAY,OAAO;AACd,iBAAA,OAAO,SAAS,YAAY,KAAK;AAAA,QAAA;AAG1C,YAAI,iBAAiB,OAAO;AACnB,iBAAA,OAAO,YAAY,iBAAiB,KAAK;AAAA,QAAA;AAG9C,YAAA,OAAO,YAAY;AACd,iBAAA,IAAI,OAAO,SAAU,CAAA;AAAA,QAAA;AAGxB,cAAA,WAAW,MAAM,MAAM,GAAG;AAE5B,YAAA,CAAC,SAAS,IAAI;AACV,gBAAA,IAAI,MAAM,0BAA0B;AAAA,QAAA;AAGtC,cAAA,OAAO,MAAM,SAAS,KAAK;AACjC,iBAAS,QAAQ,KAAK;AAGhB,cAAA,uCAAuB,IAAY;AACpC,aAAA,SAAS,QAAQ,CAAC,YAAqB;AAC1C,cAAI,QAAQ,UAAU;AACH,6BAAA,IAAI,QAAQ,QAAQ;AAAA,UAAA;AAAA,QACvC,CACD;AAEU,mBAAA,QAAQ,MAAM,KAAK,gBAAgB;AAAA,eACvC,KAAU;AACjB,cAAM,QAAQ,IAAI;AAAA,MAAA,UAClB;AACA,gBAAQ,QAAQ;AAAA,MAAA;AAAA,IAClB;AAIF,UAAM,CAAC,aAAa,gBAAgB,GAAG,SAAS,MAAM;AACtC,oBAAA;AAAA,IAChB,GAAG,GAAG,CAAC;AAQP,aAAS,YAAY,OAAe;AAC3B,aAAA,IAAI,KAAK,aAAa,SAAS;AAAA,QACpC,OAAO;AAAA,QACP,UAAU;AAAA,MAAA,CACX,EAAE,OAAO,KAAK;AAAA,IAAA;AAIN,eAAA;AAAA,MACT,OAAO;AAAA,MACP,aAAa;AAAA,IAAA,CACd;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;","names":[],"sources":["../../../../pages/products.vue"],"sourcesContent":["<script setup lang=\"ts\">\r\ninterface Product {\r\n  id: number;\r\n  name: string;\r\n  description: string;\r\n  price: number;\r\n  stock: number;\r\n  category: string;\r\n  image_url?: string;\r\n}\r\n\r\nconst products = ref<Product[]>([]);\r\nconst loading = ref(true);\r\nconst error = ref(null);\r\nconst searchQuery = ref('');\r\nconst selectedCategory = ref('');\r\nconst categories = ref<string[]>([]);\r\n\r\n// Fetch all products\r\nasync function fetchProducts() {\r\n  loading.value = true;\r\n  error.value = null;\r\n  \r\n  try {\r\n    // Build query string with filters\r\n    let url = '/api/products';\r\n    const params = new URLSearchParams();\r\n    \r\n    if (searchQuery.value) {\r\n      params.append('query', searchQuery.value);\r\n    }\r\n    \r\n    if (selectedCategory.value) {\r\n      params.append('category', selectedCategory.value);\r\n    }\r\n    \r\n    if (params.toString()) {\r\n      url += `?${params.toString()}`;\r\n    }\r\n    \r\n    const response = await fetch(url);\r\n    \r\n    if (!response.ok) {\r\n      throw new Error('Failed to fetch products');\r\n    }\r\n    \r\n    const data = await response.json();\r\n    products.value = data.products;\r\n    \r\n    // Extract unique categories from products\r\n    const uniqueCategories = new Set<string>();\r\n    data.products.forEach((product: Product) => {\r\n      if (product.category) {\r\n        uniqueCategories.add(product.category);\r\n      }\r\n    });\r\n    \r\n    categories.value = Array.from(uniqueCategories);\r\n  } catch (err: any) {\r\n    error.value = err.message;\r\n  } finally {\r\n    loading.value = false;\r\n  }\r\n}\r\n\r\n// Watch for changes in search query or category filter\r\nwatch([searchQuery, selectedCategory], debounce(() => {\r\n  fetchProducts();\r\n}, 300));\r\n\r\n// Initial fetch\r\nonMounted(() => {\r\n  fetchProducts();\r\n});\r\n\r\n// Format price to display in currency format\r\nfunction formatPrice(price: number) {\r\n  return new Intl.NumberFormat('en-US', {\r\n    style: 'currency', \r\n    currency: 'USD'\r\n  }).format(price);\r\n}\r\n\r\n// Set page metadata\r\nuseSeoMeta({\r\n  title: 'Products - Office 365 Retail Store',\r\n  description: 'Browse our Office 365 products and plans'\r\n})\r\n</script>\r\n\r\n<template>\r\n  <div class=\"max-w-6xl mx-auto px-4 py-8\">\r\n    <h1 class=\"text-3xl font-bold mb-6\">Office 365 Products</h1>\r\n    \r\n    <!-- Filters and Search -->\r\n    <div class=\"mb-8 bg-white p-4 rounded-lg shadow\">\r\n      <div class=\"flex flex-col md:flex-row gap-4\">\r\n        <div class=\"flex-1\">\r\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Search Products</label>\r\n          <input\r\n            v-model=\"searchQuery\"\r\n            type=\"text\"\r\n            placeholder=\"Search by name or description...\"\r\n            class=\"w-full px-4 py-2 border rounded-md\"\r\n          />\r\n        </div>\r\n        \r\n        <div class=\"md:w-64\">\r\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Filter by Category</label>\r\n          <select\r\n            v-model=\"selectedCategory\"\r\n            class=\"w-full px-4 py-2 border rounded-md\"\r\n          >\r\n            <option value=\"\">All Categories</option>\r\n            <option v-for=\"category in categories\" :key=\"category\" :value=\"category\">\r\n              {{ category }}\r\n            </option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- Loading and Error States -->\r\n    <div v-if=\"loading\" class=\"flex justify-center py-12\">\r\n      <div class=\"inline-block animate-spin rounded-full h-8 w-8 border-4 border-blue-500 border-t-transparent\"></div>\r\n    </div>\r\n    \r\n    <div v-else-if=\"error\" class=\"bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded\">\r\n      {{ error }}\r\n    </div>\r\n    \r\n    <!-- Product Grid -->\r\n    <div v-else-if=\"products.length === 0\" class=\"text-center py-12\">\r\n      <p class=\"text-xl text-gray-600\">No products found matching your criteria.</p>\r\n    </div>\r\n    \r\n    <div v-else class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n      <div v-for=\"product in products\" :key=\"product.id\" class=\"bg-white rounded-lg shadow overflow-hidden hover:shadow-lg transition-shadow\">\r\n        <div class=\"p-5\">\r\n          <div class=\"text-sm text-blue-600 font-semibold mb-1\">{{ product.category }}</div>\r\n          <h2 class=\"text-lg font-bold mb-2\">{{ product.name }}</h2>\r\n          <p class=\"text-gray-600 text-sm mb-4 line-clamp-2\">{{ product.description }}</p>\r\n          \r\n          <div class=\"flex justify-between items-center\">\r\n            <span class=\"text-xl font-bold text-blue-700\">{{ formatPrice(product.price) }}<span class=\"text-sm font-normal\">/month</span></span>\r\n            \r\n            <NuxtLink :to=\"`/product/${product.id}`\" class=\"bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md transition\">\r\n              View Details\r\n            </NuxtLink>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template> "],"version":3}